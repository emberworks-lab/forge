#!/usr/bin/env bash
# SessionStart hook for forge plugin.
# Injects routing rules that (a) tie-break overlapping concerns to forge skills
# over their superpowers equivalents, and (b) override superpowers' aggressive
# "invoke at 1% chance" instruction with deliberate calibration.
#
# Content lives in routing-rules.md next door; this script wraps and JSON-encodes
# it for Claude Code's SessionStart additionalContext channel.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
content=$(cat "${SCRIPT_DIR}/routing-rules.md" 2>/dev/null || printf 'Error reading forge routing-rules.md')

# JSON-escape: backslash, double-quote, newline, carriage return, tab.
# Each substitution is a single C-level pass (fast, dependency-free).
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Build raw context with real newlines and literal characters; escape the whole
# thing in one pass at the end so we never have to track double-escaping.
session_context_raw="<EXTREMELY_IMPORTANT>
forge plugin skill routing — these rules OVERRIDE the superpowers using-superpowers \"invoke at 1% chance\" instruction. They apply in any project where forge is installed and especially where .claude/tracker.json exists.

${content}
</EXTREMELY_IMPORTANT>"

session_context=$(escape_for_json "$session_context_raw")

# Emit all three additionalContext shapes for cross-host compatibility
# (Claude Code nested, Cursor snake_case, Copilot top-level camelCase).
printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"},"additionalContext":"%s","additional_context":"%s"}\n' \
    "$session_context" "$session_context" "$session_context"
